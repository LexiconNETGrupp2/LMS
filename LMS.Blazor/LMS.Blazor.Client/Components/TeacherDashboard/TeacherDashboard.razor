@inject IApiService ApiService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<div class="container">
    <h1 class="h1 fs-3 fw-bold">Lärarens Dashboard</h1>
</div>

@* <AuthorizeView>
    <Authorized>
        Hejsan Lärare @context.User.Identity?.Name
    </Authorized>
</AuthorizeView> *@

<TeacherOverview Courses="courses" />

@code {
    private IReadOnlyCollection<CourseDto>? courses;
    private bool isLoading = false;

    protected async override Task OnInitializedAsync()
    {
        await Init();
    }

    private async Task Init()
    {
        // AFAIK this component can only load if the current user is a teacher + api also has validation
        string today = DateOnly.FromDateTime(DateTime.Now).ToString("yyyy-MM-dd");
        courses = await ApiService.GetAsync<IReadOnlyCollection<CourseDto>>($"api/courses?afterDate={today}&beforeDate={today}");
    }
}
