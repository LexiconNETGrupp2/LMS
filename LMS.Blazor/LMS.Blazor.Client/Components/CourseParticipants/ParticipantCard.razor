@namespace LMS.Blazor.Client.Components.CourseParticipants

<article class="card participant-card h-100 border-0 bg-light-subtle shadow-sm">
    <div class="card-body d-flex flex-column align-items-center text-center p-4">
        <div class="rounded-circle @AvatarColor d-inline-flex align-items-center justify-content-center fw-semibold mb-4"
             style="width: 4rem; height: 4rem;">
            @Participant.Initials
        </div>

        <h5 class="h5 mb-2">@Participant.FullName</h5>

        <p class="text-muted mb-0 d-flex align-items-center justify-content-center gap-2 flex-wrap">
            <span>@Participant.Email</span>
        </p>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public ParticipantViewModel Participant { get; set; } = new();

    [Parameter]
    public string AvatarColor { get; set; } = "bg-primary-subtle";
}
