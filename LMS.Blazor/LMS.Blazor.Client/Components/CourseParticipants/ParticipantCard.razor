@namespace LMS.Blazor.Client.Components.CourseParticipants

<article class="card h-100 border-0 bg-light-subtle shadow-sm">
    <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle @AvatarColor d-inline-flex align-items-center justify-content-center fw-semibold"
             style="width: 3rem; height: 3rem;">
            @Participant.Initials
        </div>

        <div class="min-w-0">
            <h3 class="h5 mb-1">@Participant.FullName</h3>
            <p class="text-muted mb-0">@Participant.Email</p>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public ParticipantViewModel Participant { get; set; } = new();

    [Parameter]
    public string AvatarColor { get; set; } = "bg-primary-subtle";
}
