@namespace LMS.Blazor.Client.Components.CourseOverview

<div class="list-group-item py-3">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <span class="fw-semibold ms-1">@Activity.Title</span>
            <span class="badge rounded-pill bg-primary bg-opacity-75">@Activity.Type</span>

            <p class="text-muted mb-0">
                <i class="bi bi-calendar"></i>
                @Activity.Date
             </p>
        </div>
        <div class="text-end">
            @if (Activity.HasDocument)
            {
                <span class="text-primary me-3">
                    <i class="bi bi-file-text"></i>
                    Dokument
                </span>
            }
            <span class="@($"fw-medium {Activity.StatusTextClass}")">
                @if (!string.IsNullOrEmpty(Activity.StatusIcon))
                {
                    <i class="bi bi-@Activity.StatusIcon pe-2"></i>
                }
                @Activity.StatusText
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ActivityViewModel Activity { get; set; } = new();
}
