@namespace LMS.Blazor.Client.Components.CourseOverview

<div class="container py-4">
    <div class="mb-4">
        <h1 class="h2 fw-bold mb-2">@Course.Title</h1>
        <p class="text-muted mb-2">@Course.Description</p>
        <p class="text-muted mb-0">
            <i class="bi bi-calendar"></i>
            @Course.DateRange
        </p>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header">
            <h2 class="h4 fw-semibold mb-3">Kursframsteg</h2>
        </div>
        <div class="card-body p-4">
            <p class="mb-3">
                <span class="fs-2 fw-bold text-primary">@Course.ProgressPercent%</span>
                <span class="text-muted ms-1">avklarat</span>
            </p>
            <div class="progress"
                 role="progressbar"
                 aria-label="Kursframsteg"
                 aria-valuenow="@Course.ProgressPercent"
                 aria-valuemin="0"
                 aria-valuemax="100">
                <div class="progress-bar" style="width: @(Course.ProgressPercent)%;"></div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header">
            <h2 class="h3 fw-semibold mb-3">Moduler</h2>
        </div>
        <div class="card-body p-0 m-0">
            <div class="accordion">
                <Virtualize Context="module" Items="Course.Modules.ToArray()">
                    <ItemContent>
                        <ModuleItem Module="module"/>
                    </ItemContent>
                    <EmptyContent>
                        <div class="p-5">
                            <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                            <p class="text-muted">Inga moduler hittades.</p>
                        </div>
                    </EmptyContent>
                </Virtualize>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CourseOverviewViewModel Course { get; set; } = new();
}
