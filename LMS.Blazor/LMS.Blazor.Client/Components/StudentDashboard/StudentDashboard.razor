            StartDate: new DateTime(2023,9,5,9,0,0),
            EndDate:   new DateTime(2023,9,5,12,0,0),
            Type: new ActivityTypeDto("Övning"),
            ModuleId: Guid.Parse(guidStr)
        ),
        new ActivityDto(
            Id: Guid.NewGuid(),
            Name: "React Hooks",
