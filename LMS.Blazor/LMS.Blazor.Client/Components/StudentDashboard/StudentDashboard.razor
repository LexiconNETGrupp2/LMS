<div class="container py-3">
  <div class="row mb-3">
    <div class="col">
      <h5 class="mb-1">Välkommen tillbaka!</h5>
      <small class="text-muted">Veckans aktiviteter</small>
    </div>
    <div class="col-auto align-self-center">
      <button class="btn btn-sm btn-outline-primary">Visa alla</button>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card mb-3">
        <div class="card-body p-2">
          <ActivityList Items="@ActivityItems" />
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="row g-3">
        <div class="col-12">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">Kommande inlämningar</h6>
              <UpcomingSubmissions Items="@SubmissionItems" />
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">Modulfremsteg</h6>
              <ModuleProgress Items="@ProgressItems" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

