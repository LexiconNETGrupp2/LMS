@attribute [Authorize]

<div class="container py-3">
    <div class="row mb-3">
        <div class="col">
            <h5 class="mb-1">Välkommen tillbaka!</h5>
            <small class="text-muted">Veckans aktiviteter</small>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <div class="card mb-0">
                <div class="card-body p-2">
                    <ActivityList Activities="activities" ModuleId="moduleId" />
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6 col-12">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Kommande inlämningar</h6>
                    <UpcomingSubmissions Items="@SubmissionItems" />
                </div>
            </div>
        </div>

        <div class="col-lg-6 col-12">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">Modulfremsteg</h6>
                    <ModuleProgress Items="@ProgressItems" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private const string guidStr = "11111111-2222-3333-4444-555555555555";
    private readonly Guid moduleId = Guid.Parse(guidStr); // example module id

    private IEnumerable<ActivityDto> activities = new List<ActivityDto>
    {
        new ActivityDto(
            Id: Guid.NewGuid(),
            Name: "Introduktion till React",
            Description: "Föreläsning om React - intro",
            StartDate: new DateTime(2023,9,4,9,0,0),
