@implements IDisposable
@inject NavigationManager NavigationManager

<div class="top-row navmenu-top-row ps-3 navbar">
    <div class="container-fluid">
        <div class="brand-group navmenu-brand">
            <svg xmlns="http://www.w3.org/2000/svg"
                 width="30"
                 height="30"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="#2563eb"
                 stroke-width="2"
                 stroke-linecap="round"
                 stroke-linejoin="round"
                 class="lucide lucide-book-open"
                 aria-hidden="true">
                <path d="M12 7v14"></path>
                <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path>
            </svg>

            <a class="brand-text" href="">Lexicon LMS</a>
        </div>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized Context="authState">
                @if (authState.User.IsInRole("Student"))
                {
                    @foreach (var item in StudentMenuItems)
                    {
                        <NavMenuItem Icon="@item.Icon"
                                     Text="@item.Text"
                                     Href="@item.Href"
                                     Match="@item.Match" />
                    }
                }
                else if (authState.User.IsInRole("Teacher"))
                {
                    @foreach (var item in TeacherMenuItems)
                    {
                        <NavMenuItem Icon="@item.Icon"
                                     Text="@item.Text"
                                     Href="@item.Href"
                                     Match="@item.Match" />
                    }
                }
            </Authorized>

            <NotAuthorized>
                <NavMenuItem Icon="bi bi-person-badge-nav-menu"
                             Text="Login"
                             Href="Account/Login" />
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    private List<NavMenuItemModel> StudentMenuItems => new()
    {
        new("bi bi-house", "Dashboard", "", NavLinkMatch.All),
        new("bi bi-book", "Min kurs", "weather"),
        new("bi bi-file-earmark-text", "Inlämningar", "counter"),
        new("bi bi-people", "Kursdeltagare", "auth")
    };

    private List<NavMenuItemModel> TeacherMenuItems => new()
    {
        new("bi bi-house", "Dashboard", "", NavLinkMatch.All),
        new("bi bi-book", "Kurser", "weather"),
        new("bi bi-plus-circle", "Skapa ny kurs", "counter"),
        new("bi bi-people", "Användare", "auth"),
        new("bi bi-list-task", "Inlämningar", "demoauth")
    };

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}