        };
    }

    private string CourseName(Guid? courseId) =>
        Courses.SingleOrDefault(s => s.Id == courseId)?.Name ?? string.Empty;

    private string RoleName(string role) =>
        role switch
        {
            RolesNames.Student => "Elev",
            RolesNames.Teacher => "Lärare",
            _ => role
        };


    private void SetRoleFilter(string? role)
    {
        roleFilter = role;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
    }
}
