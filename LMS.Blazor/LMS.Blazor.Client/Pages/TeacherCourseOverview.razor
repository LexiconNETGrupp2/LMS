        new() { Label = "Moduler", Url = "/courses/1/modules" },
        new() { Label = "Inlämningar", Url = "/courses/1/assignments" },
        new() { Label = "Studenter", Url = "/courses/1/students" },
        new() { Label = "Dokument", Url = "/courses/1/documents" }
    };
}
