@page "/demoauth"
@inject IApiService ApiService
@* @rendermode InteractiveWebAssembly *@                                               @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode)  *@                             @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: true)) *@             @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@            @* false *@

@attribute [Authorize]

<PageTitle>Demo Auth</PageTitle>

<h3>Demo: Calling Protected API</h3>

@* <p>This page demonstrates calling the remote API through the BFF proxy (Blazor server) with JWT tokens.</p> *@
<div class="alert alert-info mb-3">
    <h5>How This Works</h5>
    <p>
        This page demonstrates calling a protected API through the BFF (Backend-for-Frontend) proxy pattern.
        With <strong>.NET 8+ Authentication State Serialization</strong>, this works seamlessly with prerendering enabled.
    </p>
    <ul class="mb-0">
        <li><strong>Prerender:</strong> Page renders on server, API call succeeds because authentication state is available</li>
        <li><strong>WASM Load:</strong> After client loads, component re-initializes and data is already available</li>
        <li><strong>BFF Proxy:</strong> All API calls go through the server's proxy controller, which handles JWT tokens</li>
    </ul>
</div>

<button class="btn btn-primary" @onclick="CallApi" disabled="@isLoading">
    @if (isLoading) {
        <span class="spinner-border spinner-border-sm me-2"></span>
    }
    Refresh API
</button>

@if (error.Count > 0) {
    <div class="alert alert-danger mt-3">
        <strong>Error(s):</strong> 
        @foreach (string e in error)
        {
            <div>@e</div>
        }
    </div>
}

@if (users != null && !users.Any()) {
    <div class="alert alert-info mt-3">
        No users were returned.
    </div>
}

@if (users != null && users.Any()) {
    <div class="alert alert-success mt-3">
        <h4>Response from API:</h4>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users) {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div>
    All Courses
</div>
@if (courses != null && courses.Any()) {
    <table border="1">

        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>StartDate</th>
            <th>EndDate</th>
            <th>Number of Students</th>
            <th>Modules</th>
        </tr>
        @foreach (var course in courses) {
            <tr>
                <td class="px-4">@course.Name</td>
                <td class="px-4">@course.Description</td>
                <td class="px-4">@course.StartDate.ToString("yyyy-MM-dd")</td>
                <td class="px-4">@course.EndDate.ToString("yyyy-MM-dd")</td>
                <td class="px-4">@course.NumberOfStudents</td>
                <td class="px-4">
                    <table>
                        <tr>
                            <th>Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                        </tr>
                        @foreach (var module in course.Modules) {
                            <tr>
                                <td class="px-4">@module.Name</td>
                                <td class="px-4">@module.StartDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-4">@module.EndDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </table>
                </td>
            </tr>
        }
    </table>
}
<div>
    Course By Id
</div>
<table>
    @if (course is not null) {
        <tr>
            <td class="px-4">@course.Name</td>
            <td class="px-4">@course.Description</td>
            <td class="px-4">@course.StartDate.ToString("yyyy-MM-dd")</td>
            <td class="px-4">@course.EndDate.ToString("yyyy-MM-dd")</td>
            <td class="px-4">@course.NumberOfStudents</td>
            <td class="px-4">
                <table>
                    <tr>
                        <th>Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                    </tr>
                    @foreach (var module in course.Modules) {
                        <tr>
                            <td class="px-4">@module.Name</td>
                            <td class="px-4">@module.StartDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-4">@module.EndDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </table>
            </td>
        </tr>
    }
</table>
<div>
    The course(s) you are currently in (@userId)
</div>
<table>
    @if (myCourses is not null) {
        <tr>
            <td class="px-4">@myCourses.Name</td>
            <td class="px-4">@myCourses.Description</td>
            <td class="px-4">@myCourses.StartDate.ToString("yyyy-MM-dd")</td>
            <td class="px-4">@myCourses.EndDate.ToString("yyyy-MM-dd")</td>
            <td class="px-4">@myCourses.NumberOfStudents</td>
            <td class="px-4">
                <table>
                    <tr>
                        <th>Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                    </tr>
                    @foreach (var module in myCourses.Modules) {
                        <tr>
                            <td class="px-4">@module.Name</td>
                            <td class="px-4">@module.StartDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-4">@module.EndDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </table>
            </td>
        </tr>
    }
</table>


@code {
    private IEnumerable<DemoAuthDto>? users;
    private List<string> error = [];
    private bool isLoading;

    private IReadOnlyCollection<CourseDto>? courses;
    private CourseDto? myCourses;
    private CourseDto? course;
    // Change to get for different accounts or different courses
    private Guid userId = Guid.Parse("479fec36-7876-48d9-8ca7-641c0b1e930c");
    private Guid courseId = Guid.Parse("a89a2c99-407a-468c-8ae6-88877ed5d948");

    protected override async Task OnInitializedAsync()
    {
        //This method run in prerender
        await CallApi();
        await CreateCourse();
        await UpdateCourse();
        await DeleteCourse();
    }

    private async Task CallApi()
    {
        isLoading = true;
        error.Clear();
        users = null;
        courses = null;
        course = null;
        myCourses = null;

        try {
            users = await ApiService.GetAsync<IEnumerable<DemoAuthDto>>("api/demoauth");
        } catch (Exception ex) {
            error.Add(ex.Message);
        } finally {
            isLoading = false;
        }

        isLoading = true;
        try {
            courses = await ApiService.GetAsync<IReadOnlyCollection<CourseDto>>("api/courses");
            if (courses is not null) {
                foreach (var c in courses) {
                    Console.WriteLine($"{c.StartDate} {c.EndDate}");
                }
            }
        } catch (Exception) {
            error.Add("401: You're not allowed see all courses");
        } finally {
            isLoading = false;
        }

        isLoading = true;
        try {
            course = await ApiService.GetAsync<CourseDto>($"api/courses/{courseId}");
            Console.WriteLine($"{course?.StartDate} {course?.EndDate}");
        } catch (Exception) {
            error.Add("401: You are not allowed to see this course");
        } finally {
            isLoading = false;
        }

        isLoading = true;
        try {
            myCourses = await ApiService.GetAsync<CourseDto?>($"api/courses/user/{userId}");
        } catch (Exception) {
            error.Add("401: You can only see your own course");
        } finally {
            isLoading = false;
        }
    }

    private async Task CreateCourse()
    {
        CreateCourseDto createCourseDto = new(
            Name: "Demoauth",
            Description: "Created from demoauth",
            StartDate: new DateOnly(2025, 1, 1),
            EndDate: new DateOnly(2026, 1, 1),
            Modules: []
        );

        var result = await ApiService.PostAsync<CreateCourseDto, bool>("api/courses/create", createCourseDto);
    }

    private async Task UpdateCourse()
    {
        UpdateCourseDto updateCourseDto = new(
            Name: "JavaScript 3: Callback",
            Description: "Created from demoauth",
            null, null
        );
        string courseId = "78dc2759-824c-4587-b5bd-2d52132e54c1";
        var result = await ApiService.PatchAsync<UpdateCourseDto, bool>($"api/courses/update/{courseId}", updateCourseDto);
    }

    private async Task DeleteCourse()
    {
        string courseId = "78dc2759-824c-4587-b5bd-2d52132e54c1";
        await ApiService.DeleteAsync($"api/courses/delete/{courseId}");
    }
}