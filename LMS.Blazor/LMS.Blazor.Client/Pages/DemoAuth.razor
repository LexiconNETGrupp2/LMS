@page "/demoauth"
@inject IApiService ApiService
@* @rendermode InteractiveWebAssembly *@                                               @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode)  *@                             @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: true)) *@             @* true *@
@* @rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false)) *@            @* false *@

@attribute [Authorize]

<PageTitle>Demo Auth</PageTitle>

<h3>Demo: Calling Protected API</h3>

@* <p>This page demonstrates calling the remote API through the BFF proxy (Blazor server) with JWT tokens.</p> *@
<div class="alert alert-info mb-3">
    <h5>How This Works</h5>
    <p>
        This page demonstrates calling a protected API through the BFF (Backend-for-Frontend) proxy pattern.
        With <strong>.NET 8+ Authentication State Serialization</strong>, this works seamlessly with prerendering enabled.
    </p>
    <ul class="mb-0">
        <li><strong>Prerender:</strong> Page renders on server, API call succeeds because authentication state is available</li>
        <li><strong>WASM Load:</strong> After client loads, component re-initializes and data is already available</li>
        <li><strong>BFF Proxy:</strong> All API calls go through the server's proxy controller, which handles JWT tokens</li>
    </ul>
</div>

<button class="btn btn-primary" @onclick="CallApi" disabled="@isLoading">
    @if (isLoading) {
        <span class="spinner-border spinner-border-sm me-2"></span>
    }
    Refresh API
</button>

@if (error != null) {
    <div class="alert alert-danger mt-3">
        <strong>Error:</strong> @error
    </div>
}

@if (users != null && !users.Any()) {
    <div class="alert alert-info mt-3">
        No users were returned.
    </div>
}

@if (users != null && users.Any()) {
    <div class="alert alert-success mt-3">
        <h4>Response from API:</h4>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users) {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (courses != null && courses.Any()) {
    <table border="1">
        <caption>
            All Courses
        </caption>

        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>StartDate</th>
            <th>EndDate</th>
            <th>Modules</th>
        </tr>
        @foreach (var course in courses) {
            <tr>
                <td class="px-4">@course.Name</td>
                <td class="px-4">@course.Description</td>
                <td class="px-4">@course.StartDate</td>
                <td class="px-4">@course.EndDate</td>
                <td class="px-4">
                    <table>
                        <tr>
                            <th>Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                        </tr>
                        @foreach (var module in course.Modules) {
                            <tr>
                                <td class="px-4">@module.Name</td>
                                <td class="px-4">@module.StartDate</td>
                                <td class="px-4">@module.EndDate</td>
                            </tr>
                        }
                    </table>
                </td>
            </tr>
        }
    </table>
    <table>
        <caption>
            Course By Id
        </caption>
        @if (course is not null) {
            <tr>
                <td class="px-4">@course.Name</td>
                <td class="px-4">@course.Description</td>
                <td class="px-4">@course.StartDate</td>
                <td class="px-4">@course.EndDate</td>
                <td class="px-4">
                    <table>
                        <tr>
                            <th>Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                        </tr>
                        @foreach (var module in course.Modules) {
                            <tr>
                                <td class="px-4">@module.Name</td>
                                <td class="px-4">@module.StartDate</td>
                                <td class="px-4">@module.EndDate</td>
                            </tr>
                        }
                    </table>
                </td>
            </tr>
        }
    </table>
    <table>
        <caption>
            The course(s) you are currently in
        </caption>
        @if (myCourses is not null && myCourses.Any()) {
            @foreach (var course in myCourses) {
                <tr>
                    <td class="px-4">@course.Name</td>
                    <td class="px-4">@course.Description</td>
                    <td class="px-4">@course.StartDate</td>
                    <td class="px-4">@course.EndDate</td>
                    <td class="px-4">
                        <table>
                            <tr>
                                <th>Name</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                            </tr>
                            @foreach (var module in course.Modules) {
                                <tr>
                                    <td class="px-4">@module.Name</td>
                                    <td class="px-4">@module.StartDate</td>
                                    <td class="px-4">@module.EndDate</td>
                                </tr>
                            }
                        </table>
                    </td>
                </tr>
            }
        }
    </table>
}

@code {
    private IEnumerable<DemoAuthDto>? users;
    private string? error;
    private bool isLoading;

    private IEnumerable<CourseDto>? courses;
    private IEnumerable<CourseDto>? myCourses;
    private CourseDto? course;
    // Change to get for different accounts
    private Guid userId = Guid.Parse("5f5ff588-d075-4794-96a7-8eeb7a99ffb8");


    protected override async Task OnInitializedAsync()
    {
        //This method run in prerender
        await CallApi();
    }

    private async Task CallApi()
    {
        isLoading = true;
        error = null;
        users = null;

        try {
            users = await ApiService.GetAsync<IEnumerable<DemoAuthDto>>("api/demoauth");
            courses = await ApiService.GetAsync<IEnumerable<CourseDto>>("api/courses");
            var courseId = courses?.FirstOrDefault()?.Id;
            course = (await ApiService.GetAsync<CourseDto>($"api/courses/course/{courseId}"));
            myCourses = (await ApiService.GetAsync<IEnumerable<CourseDto>>($"api/courses/user/{userId}"));
        } catch (Exception ex) {
            error = ex.Message;
        } finally {
            isLoading = false;
        }
    }
}