@page "/create-course"
@inject IApiService ApiService

<PageTitle>Skapa Kurs</PageTitle>

<CreateCourseForm Course="_course"
                  OnAddModule="AddModule"
                  OnRemoveModule="RemoveModule"
                  OnCreateCourse="SubmitCourse"
                  OverlapErrors="_overlapErrors" />

@code {
    private CourseFormModel _course;
    private List<string> _overlapErrors = [];

    protected override void OnInitialized()
    {
        _course = new() { Id = Guid.NewGuid() };
        AddModule();
    }

    private void AddModule()
    {
        _course.Modules.Add(new() {
            ModuleId = Guid.NewGuid(),
            CourseId = _course.Id
        });
    }

    private void RemoveModule(Guid? id)
    {
        if (id is null) return;
        var module = _course.Modules.FirstOrDefault(module => module.ModuleId == id);
        if (module is null) return;
        _course.Modules.Remove(module);
        Console.WriteLine("Removing module");
    }

    private async Task SubmitCourse()
    {
        CheckForOverlap();
        // if (_overlapErrors.Count > 0) {
        //     Console.Write($"Errors occured: {Environment.NewLine}");
        //     foreach (var error in _overlapErrors) {
        //         Console.Write($"- {error}");
        //         Console.WriteLine();
        //         return;
        //     }
        // }

        CreateCourseDto createCourseDto = new() {
            Name = _course.Name,
            Description = _course.Description,
            StartDate = (DateOnly)_course.StartDate!,
            EndDate = (DateOnly)_course.EndDate!,
            Modules = _course.Modules.Select(m => new CreateModuleDto(
                Name: m.Name,
                //Description: m.Description,
                StartDate: (DateOnly)m.StartDate!,
                EndDate: (DateOnly)m.EndDate!,
                CourseId: (Guid)m.CourseId!
            )).ToList()
        };

        bool success = await ApiService.PostAsync<CreateCourseDto, bool>("api/courses", createCourseDto);
    }

    private void CheckForOverlap()
    {
        _overlapErrors = [];
        int i = 0;
        if (_course.StartDate > _course.Modules[i].StartDate) {
            _overlapErrors.Add($"Module {_course.Modules[i].Name} is starting before the course");
        }
        for (i = 1; i < _course.Modules.Count; i++) {            
            if (_course.Modules[i - 1].EndDate >= _course.Modules[i].StartDate) {
                _overlapErrors.Add($"Modules {_course.Modules[i - 1].Name} and {_course.Modules[i].Name} are overlapping");
            }
        }
        i--;
        if (_course.EndDate < _course.Modules[i].EndDate) {
            _overlapErrors.Add($"Module {_course.Modules[i].Name} is ending after the course");
        }
    }
}