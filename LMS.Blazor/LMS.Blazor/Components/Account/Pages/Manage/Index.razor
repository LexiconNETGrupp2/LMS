@page "/Account/Manage"
@layout MainLayout
@using System.ComponentModel.DataAnnotations
@using LMS.Blazor.Client.Layout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Mitt konto</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">
            <div class="mb-4">
                <h1 class="h3 fw-semibold mb-1">Mitt konto</h1>
                <p class="text-body-secondary mb-0">Hantera dina personliga uppgifter och din kontoinformation.</p>
            </div>

            <StatusMessage Message="@message" />

            @if (isLoaded)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="manage-account">
                            <DataAnnotationsValidator />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="first-name" class="form-label fw-semibold">Förnamn</label>
                                    <InputText id="first-name" @bind-Value="Input.FirstName" class="form-control" />
                                    <ValidationMessage For="() => Input.FirstName" class="text-danger small d-block mt-1" />
                                </div>

                                <div class="col-md-6">
                                    <label for="last-name" class="form-label fw-semibold">Efternamn</label>
                                    <InputText id="last-name" @bind-Value="Input.LastName" class="form-control" />
                                    <ValidationMessage For="() => Input.LastName" class="text-danger small d-block mt-1" />
                                </div>

                                <div class="col-12">
                                    <label for="phone-number" class="form-label fw-semibold">Telefonnummer</label>
                                    <InputText id="phone-number" @bind-Value="Input.PhoneNumber" class="form-control" />
                                    <ValidationMessage For="() => Input.PhoneNumber" class="text-danger small d-block mt-1" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">E-postadress</label>
                                    <input class="form-control" value="@email" readonly />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Användarnamn</label>
                                    <input class="form-control" value="@username" readonly />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end pt-4">
                                <button type="submit" class="btn btn-primary px-4">Spara ändringar</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string? message;
    private string? email;
    private string? username;
    private ApplicationUser user = default!;
    private bool isLoaded;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        user = await GetUserAsync();

        email = await UserManager.GetEmailAsync(user);
        username = await UserManager.GetUserNameAsync(user);

        if (string.IsNullOrWhiteSpace(Input.FirstName) &&
            string.IsNullOrWhiteSpace(Input.LastName) &&
            string.IsNullOrWhiteSpace(Input.PhoneNumber))
        {
            Input = new InputModel
            {
                FirstName = user.FirstName,
                LastName = user.LastName,
                PhoneNumber = user.PhoneNumber
            };
        }

        isLoaded = true;
    }

    private async Task OnValidSubmitAsync()
    {
        user = await GetUserAsync();

        var phoneNumber = await UserManager.GetPhoneNumberAsync(user);

        if (Input.FirstName != user.FirstName)
        {
            user.FirstName = Input.FirstName.Trim();
        }

        if (Input.LastName != user.LastName)
        {
            user.LastName = Input.LastName.Trim();
        }

        if (Input.PhoneNumber != phoneNumber)
        {
            var setPhoneResult = await UserManager.SetPhoneNumberAsync(user, Input.PhoneNumber);
            if (!setPhoneResult.Succeeded)
            {
                message = "Fel: Det gick inte att uppdatera telefonnummer.";
                return;
            }
        }

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            message = "Fel: Det gick inte att uppdatera kontot.";
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        RedirectManager.RedirectToCurrentPageWithStatus("Kontot har uppdaterats.", HttpContext);
    }

    private async Task<ApplicationUser> GetUserAsync()
    {
        var currentUser = await UserManager.GetUserAsync(HttpContext.User);

        if (currentUser is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }

        return currentUser!;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Förnamn krävs.")]
        [StringLength(50, ErrorMessage = "Förnamn får vara högst 50 tecken.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Efternamn krävs.")]
        [StringLength(50, ErrorMessage = "Efternamn får vara högst 50 tecken.")]
        public string LastName { get; set; } = string.Empty;

        [Phone(ErrorMessage = "Ange ett giltigt telefonnummer.")]
        public string? PhoneNumber { get; set; }
    }
}
